# Copy to .env and fill in. .env is gitignored.

# Local Postgres (Docker container `bluven-pg`), CRM's own database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bluven_crm"

# Auth.js (NextAuth v5). Generate one with:  npx auth secret
# (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-32-byte-base64-secret"
