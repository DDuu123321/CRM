// Bluven CRM — Phase 1 data model (refined spine).
// Contact (person, dedup by email) ─< Site (property) and ─< Deal (pipeline).
// Activity is the append-only log, attached to a Deal.
// Extends later toward the concept map (Job/Installation → Compliance → Rebate…).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
  INSTALLER
}

enum LeadSource {
  WEBSITE_QUOTE
  WEBSITE_ASSESSMENT
  AI_CHAT
  WEBSITE_NEWSLETTER
  PHONE
  REFERRAL
  OTHER
}

enum PipelineStage {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum ActivityType {
  NOTE
  STAGE_CHANGE
  CALL
  EMAIL
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         Role       @default(SALES)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ownedDeals   Deal[]     @relation("DealOwner")
  activities   Activity[] @relation("ActivityActor")
}

// The person. Identity anchor — deduplicated by email (a person can have many
// sites and many deals over time).
model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String?
  email     String?  @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     Site[]
  deals     Deal[]

  @@index([phone])
}

// The property where a system goes. Separate from Contact — one person can own
// multiple sites, and a site can change owners.
model Site {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  address   String?
  suburb    String?
  state     String?
  postcode  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]

  @@index([contactId])
}

// A sales opportunity — the pipeline unit. Carries stage, source, owner.
model Deal {
  id         String        @id @default(cuid())
  contact    Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId  String
  site       Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  siteId     String?
  owner      User?         @relation("DealOwner", fields: [ownerId], references: [id])
  ownerId    String?
  title      String?
  stage      PipelineStage @default(NEW)
  source     LeadSource    @default(OTHER)
  activities Activity[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([stage])
  @@index([contactId])
  @@index([siteId])
  @@index([ownerId])
}

// Append-only. Never expose update/delete in the app — this is the audit trail
// that separates a CRM from a "forms table with a status column".
model Activity {
  id        String       @id @default(cuid())
  deal      Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId    String
  type      ActivityType @default(NOTE)
  body      String
  actor     User?        @relation("ActivityActor", fields: [actorId], references: [id])
  actorId   String?
  createdAt DateTime     @default(now())

  @@index([dealId])
}
